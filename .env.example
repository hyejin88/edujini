# EduQA — 환경 변수 템플릿
# 사용: cp .env.example .env.local 후 실제 값 입력
# .env.local 은 .gitignore 에 등록되어 절대 Git에 커밋되지 않음

# ============================================================
# Supabase (DB + Auth + Storage)
# https://supabase.com/dashboard → Project → Settings → API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ============================================================
# Gemini API (콘텐츠 생성·검증·라벨링)
# https://aistudio.google.com/app/apikey
# 무료 한도: Flash 1500 req/day, Pro 50 req/day
# ============================================================
GEMINI_API_KEY=AIzaSy...
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# ============================================================
# Anthropic Claude (학부모 리포트만 — 한국어 자연어 톤)
# https://console.anthropic.com/
# ============================================================
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ============================================================
# Cloudflare R2 (이미지 스토리지 — 10GB 무료)
# https://dash.cloudflare.com/profile/api-tokens
# ============================================================
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_R2_ACCESS_KEY_ID=...
CLOUDFLARE_R2_SECRET_ACCESS_KEY=...
CLOUDFLARE_R2_BUCKET=eduqa-images
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ============================================================
# Resend (이메일 — 학부모 주간 리포트 / 3000통 무료)
# https://resend.com/api-keys
# ============================================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=eduqa@resend.dev

# ============================================================
# Sentry (에러 트래킹 — 5K/월 무료)
# https://sentry.io
# ============================================================
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=...

# ============================================================
# PostHog (제품 분석 — 1M 이벤트/월 무료)
# https://app.posthog.com
# ============================================================
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================================
# 앱 설정
# ============================================================
NEXT_PUBLIC_APP_URL=https://eduqa.vercel.app
NEXT_PUBLIC_API_URL=https://eduqa-backend.onrender.com
NODE_ENV=development
